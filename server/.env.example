# ─── DATABASE ───────────────────────────────────────────────
# Use 127.0.0.1 instead of localhost to avoid IPv6 issues on Windows
MONGO_URI=mongodb://127.0.0.1:27017/vaultsave

# ─── JWT ────────────────────────────────────────────────────
# Any random string — keep it secret!
JWT_SECRET=myvaultsave_secret_key_2024

# ─── SERVER PORT ────────────────────────────────────────────
PORT=5000

# ─── RAZORPAY KEYS ──────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://dashboard.razorpay.com
# 2. Login / Sign up free
# 3. Make sure TEST MODE is ON (toggle top-left)
# 4. Go to Settings → API Keys → Generate Test Key
# 5. Copy Key ID and Key Secret below

RAZORPAY_KEY_ID=rzp_test_PASTE_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=PASTE_YOUR_KEY_SECRET_HERE

# ─── OPTIONAL ───────────────────────────────────────────────
# Only needed for live bank payouts (Razorpay X)
# RAZORPAY_ACCOUNT_NUMBER=
# RAZORPAY_WEBHOOK_SECRET=
